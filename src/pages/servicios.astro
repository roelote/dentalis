    <script>
        const els = document.querySelectorAll('.reveal,.reveal-l,.reveal-r');
        const io = new IntersectionObserver(
            (entries) => {
                entries.forEach((e) => {
                    if (e.isIntersecting) {
                        e.target.classList.add('in');
                        io.unobserve(e.target);
                    }
                });
            },
            { threshold: 0.1 }
        );
        els.forEach((el) => io.observe(el));
    </script>
