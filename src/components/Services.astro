---
import 'swiper/css';
import 'swiper/css/grid';
import 'swiper/css/pagination';
---

<div class="swiper Myservices">
    <div class="swiper-wrapper pb-8">
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/foto2.png" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/Imagen1b.png" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/DISENO-DE-SONRISA-2.jpg" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/foto.png" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2020/11/WhatsApp-Image-2019-02-12-at-18.24.19-1.jpg" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/Foto.jpg" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/adsa.png" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/implantes-dentales-scaled.jpg" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/implantes-dentales-scaled.jpg" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/implantes-dentales-scaled.jpg" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/implantes-dentales-scaled.jpg" /></div>
        <div class="swiper-slide"><img loading="lazy" decoding="async" class="shadow w-full h-80 lg:size-60 object-cover object-center rounded-2xl" src="https://draalcedo.com/wp-content/uploads/2024/02/implantes-dentales-scaled.jpg" /></div>
    </div>
    <div class="swiper-pagination bottom-0!"></div>
</div>

<script>
    import Swiper from 'swiper';
    import { Grid, Pagination, Autoplay } from 'swiper/modules';

    new Swiper('.Myservices', {
        modules: [Grid, Pagination, Autoplay],
        slidesPerView: 1,
        spaceBetween: 20,
        autoplay: {
            delay: 3000,
            disableOnInteraction: false,
            pauseOnMouseEnter: true,
        },
        pagination: {
            el: '.swiper-pagination',
            clickable: true,
        },
        breakpoints: {
            0: {
                slidesPerView: 1,
                spaceBetween: 30,
                grid: {
                    rows: 1,
                },
            },
            1024: {
                slidesPerView: 3,
                grid: {
                    rows: 2,
                    fill: 'row',
                },
                spaceBetween: 20,
            },
        },
    });
</script>


