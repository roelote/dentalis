---
import heroDentist from '../assets/hero-dentist.png';
import img1 from '../assets/img1.png';
import img2 from '../assets/img2.png';
import img3 from '../assets/img3.png';
import gruion from '../assets/guion.png';
import Services from './Services.astro';
---

<main>
    <section>
        <div class="w-full min-h-screen bg-amber-50 flex items-center justify-center">
            <div class="container py-10">
                <div class="flex items-center gap-10 flex-col lg:flex-row">
                    <div>
                        <span class="text-primary text-xs font-medium flex items-center gap-2 before:content-[''] before:w-[50px] before:h-[1px] before:bg-[#CA982D]"> Clinica dentista premiun • Cusco </span>
                        <h1 class="text-3xl md:text-7xl font-bold text-slate-800 leading-[1.2] my-4 text-wrap md:text-nowrap">
                            Sabias que <span class="block text-primary">Inspiran Confianza</span>
                        </h1>
                        <p class="text-base text-gray-700 max-w-4xl">En Lumina Dental combinamos tecnología de vanguardia con un trato humano excepcional para cuidar tu sonrisa con el detalle que mereces.</p>
                        <div class="mt-5 flex items-center flex-col lg:flex-row gap-5">
                            <a href="" class="text-medium lg:text-base inline-flex justify-center items-center gap-2 bg-primary text-white w-full lg:w-max lg:px-9 text-center py-3 rounded-2xl hover:bg-[#CA982D] transition-colors font-medium">Agendar Cita <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-move-right-icon lucide-move-right"><path d="M18 8L22 12L18 16"></path><path d="M2 12H22"></path></svg></a>
                            <a href="" class="text-medium lg:text-base inline-flex justify-center  border border-slate-800 text-white w-full lg:w-max lg:px-9 text-center py-3 rounded-2xl bg-slate-800 transition-colors font-medium">Conocer Servicios</a>
                        </div>
                    </div>
                    <div class="relative">
                        <div class="absolute shadow-2xl -bottom-5 left-0 lg:-left-10 bg-white p-3 rounded-2xl">
                            <div class="flex items-center gap-3">
                                <div>
                                    <div class="bg-amber-500 p-3 rounded-full">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="#ffffff" stroke="#ffffff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-star-icon lucide-star"><path d="M11.525 2.295a.53.53 0 0 1 .95 0l2.31 4.679a2.123 2.123 0 0 0 1.595 1.16l5.166.756a.53.53 0 0 1 .294.904l-3.736 3.638a2.123 2.123 0 0 0-.611 1.878l.882 5.14a.53.53 0 0 1-.771.56l-4.618-2.428a2.122 2.122 0 0 0-1.973 0L6.396 21.01a.53.53 0 0 1-.77-.56l.881-5.139a2.122 2.122 0 0 0-.611-1.879L2.16 9.795a.53.53 0 0 1 .294-.906l5.165-.755a2.122 2.122 0 0 0 1.597-1.16z"></path></svg>
                                    </div>
                                </div>
                                <div>
                                    <p class="block text-sm text-gray-700 font-bold">+ 2,500</p>
                                    <p class="block text-xs text-gray-400">Pacientes felices</p>
                                </div>
                            </div>
                        </div>
                        <img decoding="async" fetchpriority="high" src={heroDentist.src} alt="" class="z-10 shadow-2xl rounded-[40px]" />
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section>
        <div class="container py-16 overflow-hidden" id="servicios">
            <div class="flex flex-col lg:flex-row items-center gap-10 justify-between">
                <div class="w-full lg:w-1/2">
                    <span class="text-primary text-xs font-medium flex items-center gap-2 before:content-[''] before:w-[50px] before:h-[1px] before:bg-[#CA982D]"> Clinica dentista premiun • Cusco </span>
                    <h2 class="text-3xl md:text-5xl font-bold text-slate-800 leading-[1.2] my-4">
                        Sabias que <span class="block text-primary">Inspiran Confianza</span>
                    </h2>
                    <p class="text-base text-gray-700 max-w-2xl">En Lumina Dental combinamos tecnología de vanguardia con un trato humano excepcional para cuidar tu sonrisa con el detalle que mereces.</p>
                </div>

                <div class="w-full lg:w-1/2 min-w-0">
                    <Services />
                </div>
            </div>
        </div>
    </section>
    <section>
        <div class="w-full bg-amber-50 py-16 overflow-hidden">
            <div class="container">
