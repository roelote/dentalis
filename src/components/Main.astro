                                    </div>
                                    <div class="text-center">
                                        <p class="text-3xl text-primary font-bold tracking-wide">24/7</p>
                                        <p class="text-base text-gray-200">Urgencias</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
