                    </div>
                </div>
                <div class="my-10">
                    <div class="grid grid-cols-6 gap-5 my-5">
                        <div class="col-span-6 lg:col-span-4 rounded-3xl overflow-hidden shadow-2xl relative group">
                            <img class="w-full h-full lg:h-87.5 object-cover object-center transition-transform duration-300 group-hover:scale-110" src={img1.src} alt="" />
                            <div class="absolute inset-0 bg-linear-to-t from-slate-700 to-transparent opacity-70"></div>
                            <div class="absolute left-8 bottom-8 z-50">
                                <p class="block text-primary text-lg font-medium">01 — Consulta</p>
                                <p class="block text-gray-200 text-xl font-semibold tracking-wide text-balance">Sala de Tratamiento</p>
                            </div>
                        </div>
                        <div class="col-span-6 lg:col-span-2 rounded-3xl overflow-hidden relative group">
                            <img class="w-full h-full lg:h-87.5 object-cover object-center transition-transform duration-300 group-hover:scale-110" src={img2.src} alt="" />
                            <div class="absolute inset-0 bg-linear-to-t from-slate-700 to-transparent opacity-70"></div>
                            <div class="absolute left-8 bottom-8 z-50">
                                <p class="block text-primary text-lg font-medium">02 — Recepeción</p>
                                <p class="block text-gray-200 text-xl font-semibold tracking-wide text-balance">Espacio de Bienvenida</p>
                            </div>
                        </div>
                    </div>
                    <div class="grid grid-cols-6 gap-5 my-5">
                        <div class="col-span-6 lg:col-span-2 rounded-3xl overflow-hidden relative group">
