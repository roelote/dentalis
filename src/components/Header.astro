---
import logo from "../assets/logo.svg";
---

<header>
  <div class="container">
    <div class="flex items-center justify-between py-2">
      <div>
        <a href="/" title="Dentalis">
          <img src={logo.src} alt="Astro logo" width="200" height="auto" />
        </a>
      </div>
      <div class="hidden lg:block">
        <ul class="flex items-center">
            <li><a href="#" class="text-base py-2 px-4 text-gray-700 hover:text-gray-900 font-medium transition-colors">Home</a></li>
            <li><a href="#" class="text-base py-2 px-4 text-gray-700 hover:text-gray-900 font-medium transition-colors">Servicios</a></li>
            <li><a href="#" class="text-base py-2 px-4 text-gray-700 hover:text-gray-900 font-medium transition-colors">Dentista</a></li>
            <li><a href="#" class="text-base py-2 px-4 text-gray-700 hover:text-gray-900 font-medium transition-colors">Blogs</a></li>
            <li><a href="#" class="text-base py-2 px-4 text-gray-700 hover:text-gray-900 font-medium transition-colors">About Us</a></li>
            <li><a href="#" class="text-base py-2 px-4 text-gray-700 hover:text-gray-900 font-medium transition-colors">Contact us</a></li>
        </ul>
      </div>
      <div class="hidden lg:block">
        <a href="" class="bg-primary py-2 px-5 inline-block rounded-2xl text-white text-base"> Reservar tu Cita</a>
      </div>
      <div class="block lg:hidden">
        <button type="button">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-menu-icon lucide-menu"><path d="M4 5h16"/><path d="M4 12h16"/><path d="M4 19h16"/></svg>
        </button>
      </div>
    </div>
  </div>
</header>
